# ==================================
# DevManager Frontend - Environment Variables
# ==================================

# Google Gemini API Key for AI features
# Get your key from: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Backend API URL
# Development: http://localhost:5000 (or your local backend port)
# Production: https://your-backend-api.com
VITE_API_URL=http://localhost:5000

# ==================================
# Instructions:
# ==================================
# 1. Copy this file to .env (local development)
# 2. Fill in the actual values
# 3. NEVER commit .env to Git
# 4. For production, set these variables in your hosting platform (Vercel/Netlify)
